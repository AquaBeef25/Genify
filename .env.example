# ---------------------------------------------------------------------------
# Genify — environment variables
#
# Copy this file to `.env.local` for local dev and fill in real values.
# For production, set the SAME keys in the Vercel project settings
# (Project → Settings → Environment Variables). See docs/DEPLOY.md.
#
# NOTE: env var names here are intentionally non-standard — match them exactly.
# ---------------------------------------------------------------------------

# Google Gemini API key (server-side only — never prefixed NEXT_PUBLIC).
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Supabase project URL. Dashboard → Project Settings → Data API → Project URL.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase *publishable* (anon) key — note: PUBLISHABLE, not ANON_KEY.
# Dashboard → Project Settings → API Keys → publishable key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxx

# Supabase auth UUID of the admin user — gates the /admin moderation view and
# must match ADMIN_USER_ID in supabase/schema.sql.
# Dashboard → Authentication → Users → your user → "User UID".
NEXT_PUBLIC_ADMIN_USER_ID=00000000-0000-0000-0000-000000000000

# Canonical site origin, used for sitemap.xml, robots.txt and canonical/SEO
# tags. In production set this to your deployed origin (e.g. the Vercel URL:
# https://<project>.vercel.app). If unset it falls back to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
